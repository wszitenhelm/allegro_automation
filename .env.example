# Skopiuj ten plik do .env i uzupełnij prawdziwymi danymi.
# .env NIE jest commitowany do gita (patrz .gitignore).

# Dane aplikacji Allegro API per sklep (Allegro Developer Portal -> Twoje aplikacje).
# allegro_rozliczenie.py rozlicza każdy sklep, dla którego oba pola poniżej są
# ustawione. Sklep bez ustawionych zmiennych jest po prostu pomijany.
ALLEGRO_PIGMEJKA_CLIENT_ID=
ALLEGRO_PIGMEJKA_CLIENT_SECRET=

ALLEGRO_DECOR_CLIENT_ID=
ALLEGRO_DECOR_CLIENT_SECRET=

# Opcjonalnie: podsumowanie tekstowe rozliczenia (allegro_rozliczenie.py).
# Bez tego klucza skrypt działa normalnie, tylko pomija ten krok.
# Klucz z https://console.anthropic.com/ — do LLM trafiają WYŁĄCZNIE
# zagregowane liczby per operator, nigdy treść wyciągu ani dane kupujących.
ANTHROPIC_API_KEY=
